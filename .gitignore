# ============================================================
# Maven build output
# ============================================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
# Generated by maven-shade-plugin into each module root (not just target/)
**/dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ============================================================
# ANTLR generated sources
# ============================================================
**/generated-sources/

# ============================================================
# IDE — Eclipse / IntelliJ / VS Code workspace files
# ============================================================
.idea/
*.iml
# VS Code workspace settings (not the extension itself)
.vscode/
.classpath
.project
.settings/
# Eclipse binary output folder
bin/

# ============================================================
# Compiled Java class files
# (normally covered by target/ and bin/, but catch strays too)
# ============================================================
*.class

# ============================================================
# Logs
# ============================================================
*.log

# ============================================================
# Development-only grammar scratch files
# ============================================================
grammars/

# ============================================================
# OS-generated files
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# VSCode Extension — development artifacts
# (lib/multimodelocl.jar and *.vsix are intentionally tracked
#  so the extension can be installed directly from the repo)
# ============================================================
vscode-extension/node_modules/
# Compiled TypeScript output — built before packaging, not source-controlled
vscode-extension/out/
vscode-extension/.vscode-test/
vscode-extension/npm-debug.log*
vscode-extension/yarn-debug.log*
vscode-extension/yarn-error.log*
