{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "multimodelocl",
    "scopeName": "source.multimodelocl",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#package-block"
        },
        {
            "include": "#context-block"
        },
        {
            "include": "#let-expression"
        },
        {
            "include": "#collection-literals"
        },
        {
            "include": "#iterator-ops"
        },
        {
            "include": "#type-annotations"
        },
        {
            "include": "#correspondence-operator"
        },
        {
            "include": "#enum-literal"
        },
        {
            "include": "#metamodel-reference"
        },
        {
            "include": "#ocl-operations"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#multiplicity-brackets"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.multimodelocl",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "captures": {
                        "0": {
                            "name": "punctuation.definition.comment.multimodelocl"
                        }
                    }
                },
                {
                    "name": "comment.line.double-dash.multimodelocl",
                    "match": "--.*$"
                }
            ]
        },
        "package-block": {
            "patterns": [
                {
                    "name": "keyword.other.package.multimodelocl",
                    "match": "\\b(package|endpackage)\\b"
                }
            ]
        },
        "context-block": {
            "patterns": [
                {
                    "match": "\\b(context)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:::([A-Za-z_][A-Za-z0-9_]*))?",
                    "captures": {
                        "1": {
                            "name": "keyword.control.context.multimodelocl"
                        },
                        "2": {
                            "name": "entity.name.type.class.multimodelocl"
                        },
                        "3": {
                            "name": "entity.name.function.multimodelocl"
                        }
                    }
                },
                {
                    "match": "\\b(inv|pre|post|body|def)\\b(\\s+([A-Za-z_][A-Za-z0-9_]*))?",
                    "captures": {
                        "1": {
                            "name": "keyword.other.constraint.multimodelocl"
                        },
                        "3": {
                            "name": "entity.name.label.multimodelocl"
                        }
                    }
                }
            ]
        },
        "let-expression": {
            "patterns": [
                {
                    "match": "\\b(let)\\s+([A-Za-z_][A-Za-z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.let.multimodelocl"
                        },
                        "2": {
                            "name": "variable.other.let.multimodelocl"
                        }
                    }
                },
                {
                    "name": "keyword.control.in.multimodelocl",
                    "match": "\\bin\\b"
                }
            ]
        },
        "collection-literals": {
            "patterns": [
                {
                    "begin": "\\b(Set|Sequence|Bag|OrderedSet)\\s*(\\{)",
                    "end": "(\\})",
                    "beginCaptures": {
                        "1": {
                            "name": "entity.name.type.collection.multimodelocl"
                        },
                        "2": {
                            "name": "punctuation.definition.collection.begin.multimodelocl"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "punctuation.definition.collection.end.multimodelocl"
                        }
                    },
                    "patterns": [
                        {
                            "include": "$self"
                        }
                    ]
                }
            ]
        },
        "iterator-ops": {
            "patterns": [
                {
                    "name": "support.function.iterator.multimodelocl",
                    "match": "\\b(select|reject|collect|collectNested|forAll|exists|any|one|isUnique|sortedBy|iterate)\\b"
                }
            ]
        },
        "type-annotations": {
            "patterns": [
                {
                    "name": "entity.name.type.collection.multimodelocl",
                    "match": "\\b(Set|Sequence|Bag|OrderedSet|Optional|Singleton|Collection)(?=\\s*[({<]|\\b)"
                },
                {
                    "name": "entity.name.type.primitive.multimodelocl",
                    "match": "\\b(Integer|Real|String|Boolean|UnlimitedNatural|OclAny|OclVoid|INTEGER|DOUBLE|FLOAT|BOOLEAN|STRING|ANY|ERROR)\\b"
                }
            ]
        },
        "correspondence-operator": {
            "patterns": [
                {
                    "name": "keyword.operator.correspondence.multimodelocl",
                    "match": "~"
                }
            ]
        },
        "enum-literal": {
            "match": "\\b([A-Z][A-Za-z0-9_]*)::([A-Z][A-Z0-9_]+)\\b",
            "captures": {
                "1": {
                    "name": "entity.name.type.enum.multimodelocl"
                },
                "2": {
                    "name": "variable.other.enum-member.multimodelocl"
                }
            }
        },
        "metamodel-reference": {
            "name": "entity.name.type.metamodel-reference.multimodelocl",
            "match": "\\b[A-Z][A-Za-z0-9_]*::[A-Z][A-Za-z0-9_]+\\b"
        },
        "ocl-operations": {
            "patterns": [
                {
                    "name": "support.function.string.multimodelocl",
                    "match": "\\b(concat|substring|size|indexOf|toUpperCase|toLowerCase|toInteger|toReal|trim|matches|tokenize|substituteAll|substituteFirst|characters|equalsIgnoreCase|startsWith|endsWith)\\b"
                },
                {
                    "name": "support.function.collection.multimodelocl",
                    "match": "\\b(isEmpty|notEmpty|includes|excludes|includesAll|excludesAll|sum|count|min|max|first|last|at|union|intersection|append|prepend|insertAt|subSequence|flatten|asSet|asOrderedSet|asSequence|asBag|reverse)\\b"
                },
                {
                    "name": "support.function.ocl.multimodelocl",
                    "match": "\\b(allInstances|oclIsKindOf|oclIsTypeOf|oclAsType|oclIsNew|oclIsUndefined|oclIsInvalid)\\b"
                },
                {
                    "name": "support.function.numeric.multimodelocl",
                    "match": "\\b(abs|floor|ceiling|round|sqrt|log|exp|mod|div)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.multimodelocl",
                    "match": "\\b(if|then|else|endif)\\b"
                },
                {
                    "name": "keyword.operator.logical.multimodelocl",
                    "match": "\\b(and|or|not|implies|xor)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.self.multimodelocl",
                    "match": "\\bself\\b"
                },
                {
                    "name": "constant.language.result.multimodelocl",
                    "match": "\\bresult\\b"
                },
                {
                    "name": "constant.language.boolean.multimodelocl",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.multimodelocl",
                    "match": "\\b(null|invalid|OclUndefined)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.single.multimodelocl",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.multimodelocl",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.multimodelocl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.multimodelocl",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.multimodelocl",
                    "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?[fF]?\\b"
                },
                {
                    "name": "constant.numeric.integer.multimodelocl",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.multimodelocl",
                    "match": "(=|<>|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.multimodelocl",
                    "match": "(\\+|-|\\*|/)"
                },
                {
                    "name": "keyword.operator.range.multimodelocl",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.navigation.multimodelocl",
                    "match": "\\.(?!\\.)"
                },
                {
                    "name": "keyword.operator.type-cast.multimodelocl",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.colon.multimodelocl",
                    "match": ":"
                },
                {
                    "name": "keyword.operator.pipe.multimodelocl",
                    "match": "\\|"
                }
            ]
        },
        "multiplicity-brackets": {
            "patterns": [
                {
                    "name": "punctuation.definition.type.singleton.multimodelocl",
                    "match": "[¡!]"
                },
                {
                    "name": "punctuation.definition.type.optional.multimodelocl",
                    "match": "[¿?]"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.section.parens.begin.multimodelocl",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.parens.end.multimodelocl",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.section.braces.begin.multimodelocl",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.braces.end.multimodelocl",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.section.bracket.begin.multimodelocl",
                    "match": "\\["
                },
                {
                    "name": "punctuation.section.bracket.end.multimodelocl",
                    "match": "\\]"
                }
            ]
        }
    }
}